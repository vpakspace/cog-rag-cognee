# LLM
# IMPORTANT: LLM_ENDPOINT must include /v1 suffix for Ollama's OpenAI-compatible API
LLM_PROVIDER=ollama
LLM_MODEL=llama3.1:8b
LLM_ENDPOINT=http://localhost:11434/v1
LLM_API_KEY=ollama

# Embeddings
# IMPORTANT: EMBEDDING_ENDPOINT must include /api/embed path (Ollama native API)
EMBEDDING_PROVIDER=ollama
EMBEDDING_MODEL=nomic-embed-text:latest
EMBEDDING_ENDPOINT=http://localhost:11434/api/embed
EMBEDDING_DIMENSIONS=768

# Cognee SDK requires a HuggingFace tokenizer for chunk sizing
HUGGINGFACE_TOKENIZER=gpt2

# Graph DB (Neo4j must have APOC plugin installed)
GRAPH_DATABASE_PROVIDER=neo4j
GRAPH_DATABASE_URL=neo4j://localhost:7687
GRAPH_DATABASE_USERNAME=neo4j
GRAPH_DATABASE_PASSWORD=password

# Vector DB
VECTOR_DB_PROVIDER=lancedb

# Access Control (disable for local single-user dev)
ENABLE_BACKEND_ACCESS_CONTROL=false

# Storage
STORAGE_ROOT_DIR=./cognee_data

# API
API_KEY=
API_HOST=0.0.0.0
API_PORT=8508

# Docling
DOCLING_USE_GPU=false

# UI
UI_PORT=8506
